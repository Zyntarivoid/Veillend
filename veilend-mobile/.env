## Local development env for veilend-mobile
# Copy values from .env.example and adjust for your device/emulator

# Backend API endpoints
API_URL_WEB=http://localhost:3000
API_URL_MOBILE=http://10.0.2.2:3000

# Stellar network provider
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Feature toggles
USE_MOCKS=true
ENABLE_SECURE_STORE=false

# App environment
APP_ENV=development

# Optional integrations
ANALYTICS_KEY=
SENTRY_DSN=

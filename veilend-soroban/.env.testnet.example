# Copy to .env.testnet and fill in values for Stellar testnet.

# Stellar CLI network name. The scripts default to testnet when unset.
STELLAR_NETWORK=testnet

# Funded Stellar CLI identity, secret key, or seed phrase used as transaction source.
STELLAR_SOURCE=alice

# Contract constructor admin address. Usually the public address for STELLAR_SOURCE.
VEILLEND_ADMIN=G...

# Constructor minimum collateral ratio in basis points. 15000 = 150%.
VEILLEND_MIN_COLLATERAL_RATIO_BPS=15000

# Filled after deploy-testnet.sh prints the deployed contract id.
VEILLEND_CONTRACT_ID=C...

# Example Stellar asset contract id used by configure/deposit/borrow/repay invocations.
VEILLEND_ASSET=C...

# Example user public address for position reads and user-authorized actions.
VEILLEND_USER=G...

# Optional override when using a custom WASM output path.
# VEILLEND_WASM=target/stellar/veillend_contract.wasm
